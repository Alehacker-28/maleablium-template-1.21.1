{
  "multipart": [
    {
      "when": { "OR": [ { "north": "true" }, { "south": "true" } ] },
      "apply": { 
        "model": "random_biomes:block/crimson_vines_cross", 
        "x": 90, 
        "uvlock": false 
      }
    },
    {
      "when": { "OR": [ { "east": "true" }, { "west": "true" } ] },
      "apply": { 
        "model": "random_biomes:block/crimson_vines_cross", 
        "x": 90, 
        "y": 90, 
        "uvlock": false 
      }
    },
    {
      "when": { "OR": [ { "up": "true" }, { "down": "true" } ] },
      "apply": { 
        "model": "random_biomes:block/crimson_vines_cross", 
        "uvlock": false 
      }
    }
  ]
}
